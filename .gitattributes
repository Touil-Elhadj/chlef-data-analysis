# Default: treat all text files as LF on checkout/checkin
* text=auto eol=lf

# Source files — always LF
*.php       text eol=lf
*.js        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.sql       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.cff       text eol=lf
*.bib       text eol=lf
*.txt       text eol=lf
*.env*      text eol=lf
.htaccess   text eol=lf
.gitignore  text eol=lf

# Binary files — never normalize
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.tar.gz    binary
*.gz        binary

# Exclude from GitHub language statistics (research code, big thesis PDF)
docs/Memoire_Revise.pdf linguist-vendored
