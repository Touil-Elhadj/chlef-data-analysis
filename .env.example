# ═══════════════════════════════════════════════════════════════════
# Chlef-Biostat-2026 — Environment configuration
# ───────────────────────────────────────────────────────────────────
# 1. Copy this file:        cp .env.example .env
# 2. Fill in real values:   nano .env
# 3. NEVER commit .env      (already in .gitignore)
# ═══════════════════════════════════════════════════════════════════

# ── Database (MySQL / MariaDB, utf8mb4) ────────────────────────────
DB_HOST=localhost
DB_NAME=chlef_biostat
DB_USER=biostat_user
DB_PASS=change_me_to_a_strong_password

# ── Site identity ──────────────────────────────────────────────────
SITE_NAME="Questionnaire Chlef 2026"
SITE_URL=https://example.com
ADMIN_EMAIL=admin@example.com

# ── Study parameters ───────────────────────────────────────────────
# Target sample size — used by progress.php / milestones
TARGET_N=1220

# ── Sessions & security ────────────────────────────────────────────
# Session lifetime in seconds (28800 = 8 h)
SESSION_DURATION=28800
# Max failed login attempts before lockout
MAX_LOGIN_ATTEMPTS=5
# Lockout duration in seconds (900 = 15 min)
LOCKOUT_DURATION=900

# ── Environment ────────────────────────────────────────────────────
# production | development
APP_ENV=production
# Hide PHP errors (1) or show them (0) — set 0 only locally
APP_DEBUG=0

# ── Locale ─────────────────────────────────────────────────────────
TIMEZONE=Africa/Algiers
DEFAULT_LANG=ar
