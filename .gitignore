# ─────────────────────────────────────────────────────────────────
# Secrets — NEVER commit these
# ─────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
secrets.php

# ─────────────────────────────────────────────────────────────────
# Logs (may contain user IPs / PII)
# ─────────────────────────────────────────────────────────────────
logs/*
!logs/.gitkeep
*.log

# ─────────────────────────────────────────────────────────────────
# Database dumps (may contain personal data)
# ─────────────────────────────────────────────────────────────────
*.sql.gz
*.sql.bak
backup_*.sql
dump_*.sql
database/backups/

# ─────────────────────────────────────────────────────────────────
# PHP / Composer (kept for future-proofing)
# ─────────────────────────────────────────────────────────────────
composer.lock
.phpunit.result.cache
.php-cs-fixer.cache

# ─────────────────────────────────────────────────────────────────
# OS noise
# ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────────
# Editors
# ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.buildpath
.settings/
nbproject/

# ─────────────────────────────────────────────────────────────────
# Build / temp
# ─────────────────────────────────────────────────────────────────
tmp/
temp/
cache/
*.tmp

# ────────────────────────────────────────────────────────────────────
# Composer (vendor/ is generated from composer.json, never committed)
# ────────────────────────────────────────────────────────────────────
/vendor/
composer.lock
composer.phar

