            "role": "Principal investigator"
        }
    ],
    "support": {
        "issues": "https://github.com/Touil-Elhadj/chlef-touilelhadj/issues",
        "source": "https://github.com/Touil-Elhadj/chlef-touilelhadj"
    },
    "require": {
        "php": ">=8.0",
