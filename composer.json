        "Chlef",
        "biostatistics"
    ],
    "homepage": "https://github.com/Touil-Elhadj/chlef-touilelhadj",
    "authors": [
        {
            "name": "Elhadj TOUIL",
            "email": "touilelhadj@live.com",
